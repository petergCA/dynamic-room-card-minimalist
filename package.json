{
	"name": "dynamic-room-card-minimalist",
	"version": "1.4.3",
	"description": "A dynamic minimalist room card for Home Assistant",
	"main": "src",
	"scripts": {
		"build": "npx webpack --mode production --output-filename dynamic-room-card-minimalist.js",
		"build:dev": "npx webpack --mode development --output-filename dynamic-room-card-minimalist.js",
		"deploy": "npm run build && cp dist/dynamic-room-card-minimalist.js custom_components/dynamic_room_card_minimalist/",
		"watch": "npx webpack serve",
		"docker:start": "docker compose -f docker/docker-compose.yml up",
		"docker:stop": "docker compose -f docker/docker-compose.yml down",
		"format": "prettier --write --ignore-path=.prettierignore .",
		"format:check": "prettier --check .",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/preset-env": "^7.29.0",
		"@types/node": "^25.4.0",
		"babel-loader": "^10.1.1",
		"babel-plugin-template-html-minifier": "^4.1.0",
		"prettier": "^3.8.1",
		"terser-webpack-plugin": "^5.4.0",
		"ts-loader": "^9.5.0",
		"typescript": "^5.8.0",
		"webpack": "^5.105.4",
		"webpack-cli": "^6.0.1",
		"webpack-dev-server": "^5.2.3"
	},
	"dependencies": {
		"lit": "^3.3.2"
	}
}
